# LINBO Native - Environment Configuration
# Generated by: ./setup.sh
# Output path: /etc/linbo-native/.env
#
# Manual setup: copy this file to /etc/linbo-native/.env and fill in values marked with <...>
# For automated setup, run: sudo ./setup.sh

# === Server Identity ===
LINBO_SERVER_IP=<your-server-ip>
LINBO_HOSTNAME=linbo-native
NODE_ENV=production

# === Secrets (generate with: sudo ./setup.sh) ===
# NEVER commit real values to version control
JWT_SECRET=<run ./setup.sh to generate>
INTERNAL_API_KEY=<run ./setup.sh to generate>
RSYNC_PASSWORD=<run ./setup.sh to generate>

# === Web UI ===
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Muster!

# === Sync Mode (connect to linuxmuster.net server) ===
# SYNC_ENABLED=true
# LMN_API_URL=https://10.0.0.1:8001
# LMN_API_USER=global-admin
# LMN_API_PASSWORD=Muster!
# LMN_SCHOOL=default-school

# === TLS (disable cert verification for self-signed LMN certs) ===
NODE_TLS_REJECT_UNAUTHORIZED=0

# === Network / DHCP (auto-filled by setup.sh from LMN server-info) ===
# These values are served to ALL DHCP clients (Windows, Linux, printers, TVs)
# LMN_SERVER_IP=10.0.0.1
# LINBO_DOMAIN=linuxmuster.lan
# LINBO_GATEWAY=10.0.0.254
# LINBO_DNS=10.0.0.1
# LINBO_SUBNET=10.0.0.0
# LINBO_NETMASK=255.255.0.0
# DHCP_INTERFACE=          # DHCP listen interface (auto-detected if not set)
# DHCP_CONFIG_DIR=/etc/dhcp  # DHCP config directory (default: /etc/dhcp)

# === Wake-on-LAN (optional -- uncomment for Networkbox integration) ===
# NETWORKBOX_HOST=localhost
# NETWORKBOX_PORT=8000
# WOL_BROADCAST_ADDRESS=10.0.255.255

# === Host Status Scanner (uncomment to override defaults) ===
# HOST_SCAN_ENABLED=true
# HOST_SCAN_INTERVAL_SEC=60
# HOST_SCAN_CONCURRENCY=30
# HOST_SCAN_PORT_TIMEOUT_MS=500
# HOST_OFFLINE_TIMEOUT_SEC=300

# === API Tuning (uncomment to override defaults) ===
# CORS_ORIGIN=*
# JWT_EXPIRES_IN=24h
# SSH_TIMEOUT=10000

# === Optional (uncomment to override defaults) ===
# LOG_LEVEL=info

# === LINBO Package Source (override for future LMN versions) ===
# DEB_BASE_URL=https://deb.linuxmuster.net
# DEB_DIST=lmn73
# LINBO_PKG=linuxmuster-linbo7
# GUI_PKG=linuxmuster-linbo-gui7
