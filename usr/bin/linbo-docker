#!/bin/bash
#
# linbo-docker — CLI for LINBO Docker Caching Server
#
# Usage:
#   linbo-docker setup [-s school] [-i server-ip] [-p password]
#   linbo-docker up [--dhcp]
#   linbo-docker down
#   linbo-docker status
#   linbo-docker logs [container]
#   linbo-docker update
#   linbo-docker doctor
#

set -euo pipefail

INSTALL_DIR="/opt/linbo-docker"
VERSION="1.0.0"

# Colors
if [[ -t 1 ]] && command -v tput &>/dev/null && [[ "$(tput colors 2>/dev/null || echo 0)" -ge 8 ]]; then
    RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'; BLUE='\033[0;34m'; BOLD='\033[1m'; NC='\033[0m'
else
    RED=''; GREEN=''; YELLOW=''; BLUE=''; BOLD=''; NC=''
fi

log_info()  { echo -e "${BLUE}[INFO]${NC}  $1"; }
log_error() { echo -e "${RED}[ERROR]${NC} $1"; }
log_ok()    { echo -e "  ${GREEN}[OK]${NC}    $1"; }

# =============================================================================
# setup — Auto-discovery from LMN server, generates .env
# =============================================================================
cmd_setup() {
    local lmn_ip="" lmn_pass="" school="" github_token="" dhcp_iface=""

    # Parse flags
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -s|--school)    school="$2"; shift 2 ;;
            -i|--server-ip) lmn_ip="$2"; shift 2 ;;
            -p|--password)  lmn_pass="$2"; shift 2 ;;
            -t|--token)     github_token="$2"; shift 2 ;;
            --dhcp-interface) dhcp_iface="$2"; shift 2 ;;
            -h|--help)      usage_setup; exit 0 ;;
            *)              log_error "Unknown option: $1"; usage_setup; exit 1 ;;
        esac
    done

    cd "$INSTALL_DIR"

    echo ""
    echo -e "${BLUE}+--------------------------------------------------+${NC}"
    echo -e "${BLUE}|          LINBO Docker - Setup                     |${NC}"
    echo -e "${BLUE}|     Modern Caching Server for linuxmuster.net     |${NC}"
    echo -e "${BLUE}+--------------------------------------------------+${NC}"
    echo ""

    # --- Prerequisites ---
    log_info "Checking prerequisites..."
    for cmd in docker jq curl openssl; do
        command -v "$cmd" &>/dev/null || { log_error "$cmd not found. Install it first."; exit 1; }
    done
    docker compose version &>/dev/null || { log_error "docker compose plugin not found."; exit 1; }
    log_ok "All prerequisites met"

    # --- LMN Server IP ---
    if [[ -z "$lmn_ip" ]]; then
        if [[ -t 0 ]]; then
            read -p "  LMN Server IP [10.0.0.1]: " lmn_ip
            lmn_ip="${lmn_ip:-10.0.0.1}"
        else
            log_error "LMN Server IP required. Use: linbo-docker setup -i 10.0.0.11"
            exit 1
        fi
    fi

    local api_url="https://${lmn_ip}:8001"

    # --- Password ---
    if [[ -z "$lmn_pass" ]]; then
        if [[ -t 0 ]]; then
            read -sp "  LMN API Password (global-admin): " lmn_pass
            echo ""
        else
            log_error "Password required. Use: linbo-docker setup -p 'password'"
            exit 1
        fi
    fi

    [[ -z "$lmn_pass" ]] && { log_error "Password is required."; exit 1; }

    # --- Authenticate ---
    log_info "Connecting to ${api_url}..."

    local token
    token=$(curl -sk "${api_url}/v1/auth/" -u "global-admin:${lmn_pass}" --max-time 10 2>/dev/null | tr -d '"')

    if [[ -z "$token" || "$token" == *"Wrong credentials"* || "$token" == *"detail"* ]]; then
        log_error "Authentication failed. Check IP and password."
        exit 1
    fi
    log_ok "Authenticated"

    # --- Auto-discover server-info ---
    local server_info
    server_info=$(curl -sk -H "X-API-Key: $token" "${api_url}/v1/linbo/server-info" --max-time 10 2>/dev/null)

    if [[ -z "$server_info" || "$server_info" == *"detail"* ]]; then
        log_error "server-info endpoint not available."
        log_error "Update the Authority API on your LMN server (linbo.py with server-info endpoint)."
        exit 1
    fi

    local domain gateway dns network netmask
    domain=$(echo "$server_info" | jq -r '.domainname // "linuxmuster.lan"')
    gateway=$(echo "$server_info" | jq -r '.gateway // "10.0.0.254"')
    dns="$lmn_ip"
    network=$(echo "$server_info" | jq -r '.network // ""')
    netmask=$(echo "$server_info" | jq -r '.netmask // ""')

    log_ok "Domain:    ${domain}"
    log_ok "Gateway:   ${gateway}"
    log_ok "DNS:       ${dns}"
    log_ok "Network:   ${network}/${netmask}"

    # --- School selection ---
    local school_count
    school_count=$(echo "$server_info" | jq -r '.schools | length' 2>/dev/null || echo "0")

    if [[ -n "$school" ]]; then
        # School from CLI flag — validate it exists
        local valid
        valid=$(echo "$server_info" | jq -r --arg s "$school" '.schools[] | select(. == $s)' 2>/dev/null)
        if [[ -z "$valid" ]]; then
            log_error "School '${school}' not found on LMN server."
            echo "  Available: $(echo "$server_info" | jq -r '.schools | join(", ")')"
            exit 1
        fi
        log_ok "School:    ${school}"
    elif [[ "$school_count" -eq 1 ]]; then
        school=$(echo "$server_info" | jq -r '.schools[0]')
        log_ok "School:    ${school} (only school)"
    elif [[ "$school_count" -gt 1 ]] && [[ -t 0 ]]; then
        echo ""
        echo -e "  ${BOLD}Available schools:${NC}"
        local idx=1
        while IFS= read -r s; do
            echo "    ${idx}) ${s}"
            idx=$((idx + 1))
        done < <(echo "$server_info" | jq -r '.schools[]')
        echo ""
        read -p "  Select school [1]: " choice
        choice="${choice:-1}"
        school=$(echo "$server_info" | jq -r ".schools[$((choice - 1))] // .schools[0]")
        log_ok "School:    ${school}"
    else
        school="default-school"
        log_ok "School:    ${school} (default)"
    fi

    # --- Docker server IP ---
    local docker_ip
    docker_ip=$(ip route get 1.1.1.1 2>/dev/null | awk '{for(i=1;i<=NF;i++) if($i=="src") print $(i+1)}')
    [[ -z "$docker_ip" ]] && docker_ip=$(hostname -I 2>/dev/null | awk '{print $1}')
    docker_ip="${docker_ip:-127.0.0.1}"

    if [[ -t 0 ]]; then
        echo ""
        # Show interfaces
        while IFS= read -r line; do
            local iface addr
            iface=$(echo "$line" | awk '{print $NF}')
            addr=$(echo "$line" | awk '{print $2}' | cut -d/ -f1)
            [[ "$addr" != "127.0.0.1" ]] && {
                [[ "$addr" == "$docker_ip" ]] && echo -e "  ${GREEN}*${NC} $addr ($iface)" || echo "    $addr ($iface)"
            }
        done < <(ip -4 addr show 2>/dev/null | grep 'inet ')
        echo ""
        read -p "  Docker server IP [${docker_ip}]: " ip_input
        docker_ip="${ip_input:-$docker_ip}"
    fi

    local docker_hostname
    docker_hostname=$(hostname -s 2>/dev/null || echo "linbo-docker")
    if [[ -t 0 ]]; then
        read -p "  DHCP hostname [${docker_hostname}]: " hn_input
        docker_hostname="${hn_input:-$docker_hostname}"
    fi

    log_ok "Docker IP:  ${docker_ip}"
    log_ok "Hostname:   ${docker_hostname}"

    # --- GitHub token ---
    if [[ -z "$github_token" ]] && [[ -t 0 ]]; then
        echo ""
        echo "  The web UI needs a GitHub token for npm packages."
        echo "  Create at: https://github.com/settings/tokens (scope: read:packages)"
        echo ""
        read -p "  GitHub token (leave empty to skip): " github_token
    fi

    # --- Existing .env ---
    if [[ -f "${INSTALL_DIR}/.env" ]]; then
        local modified
        modified=$(stat -c '%y' "${INSTALL_DIR}/.env" 2>/dev/null | cut -d. -f1)
        log_info "Existing .env found (${modified})"
        if [[ -t 0 ]]; then
            read -p "  Back up and overwrite? [Y/n]: " confirm
            [[ "$confirm" =~ ^[Nn] ]] && { log_info "Keeping existing .env."; exit 0; }
        fi
        cp "${INSTALL_DIR}/.env" "${INSTALL_DIR}/.env.backup.$(date +%Y%m%d-%H%M%S)"
    fi

    # --- Generate secrets ---
    local jwt_secret internal_key rsync_pw docker_gid
    jwt_secret=$(openssl rand -base64 48 | tr -d '\n')
    internal_key=$(openssl rand -hex 32)
    rsync_pw=$(openssl rand -base64 24 | tr -d '\n/+=' | head -c 32)
    docker_gid=$(stat -c '%g' /var/run/docker.sock 2>/dev/null || echo "988")

    # --- Write .env ---
    local timestamp
    timestamp=$(date -u +"%Y-%m-%dT%H:%M:%SZ")

    cat > "${INSTALL_DIR}/.env" << ENVEOF
# LINBO Docker - Environment Configuration
# Generated by: linbo-docker setup on $timestamp

# === Docker Server Identity ===
LINBO_SERVER_IP=$docker_ip
LINBO_HOSTNAME=$docker_hostname
NODE_ENV=production

# === LMN Server (auto-discovered) ===
LMN_SERVER_IP=$lmn_ip

# === Network / DHCP (auto-discovered from LMN server-info) ===
LINBO_DOMAIN=$domain
LINBO_GATEWAY=$gateway
LINBO_DNS=$dns
LINBO_SUBNET=$network
LINBO_NETMASK=$netmask

# === Sync Mode ===
SYNC_ENABLED=true
LMN_API_URL=$api_url
LMN_API_USER=global-admin
LMN_API_PASSWORD=$lmn_pass
LMN_SCHOOL=$school

# === Secrets (auto-generated) ===
JWT_SECRET=$jwt_secret
INTERNAL_API_KEY=$internal_key
RSYNC_PASSWORD=$rsync_pw

# === Web UI ===
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Muster!
GITHUB_TOKEN=${github_token:-}

# === TLS ===
NODE_TLS_REJECT_UNAUTHORIZED=0

# === Docker Socket Access ===
DOCKER_GID=$docker_gid

# === DHCP (enable with: linbo-docker up --dhcp) ===
DHCP_INTERFACE=${dhcp_iface:-eth0}
ENVEOF

    chmod 600 "${INSTALL_DIR}/.env"

    # rsyncd.secrets
    mkdir -p "${INSTALL_DIR}/config"
    echo "linbo:${rsync_pw}" > "${INSTALL_DIR}/config/rsyncd.secrets"
    chmod 644 "${INSTALL_DIR}/config/rsyncd.secrets"

    # Validate
    if (cd "$INSTALL_DIR" && docker compose config --quiet 2>/dev/null); then
        log_ok "docker compose config valid"
    else
        log_error "docker compose config validation failed!"
        exit 1
    fi

    echo ""
    echo -e "${GREEN}+--------------------------------------------------+${NC}"
    echo -e "${GREEN}|              Setup Complete                       |${NC}"
    echo -e "${GREEN}+--------------------------------------------------+${NC}"
    echo ""
    echo "  Docker IP:    ${docker_ip}"
    echo "  LMN Server:   ${lmn_ip}"
    echo "  Domain:        ${domain}"
    echo "  School:        ${school}"
    echo "  Admin login:   admin / Muster!"
    echo ""
    echo "  Start:"
    echo "    linbo-docker up              # Without DHCP"
    echo "    linbo-docker up --dhcp       # With DHCP server"
    echo ""
    echo "  Web UI: http://${docker_ip}:8080"
    echo "  API Docs: http://${docker_ip}:3000/docs"
    echo ""
}

# =============================================================================
# up — Start containers
# =============================================================================
cmd_up() {
    cd "$INSTALL_DIR"
    [[ ! -f .env ]] && { log_error "No .env found. Run: linbo-docker setup"; exit 1; }

    local profile_args=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --dhcp) profile_args="--profile dhcp"; shift ;;
            *)      shift ;;
        esac
    done

    log_info "Starting LINBO Docker containers..."
    docker compose $profile_args up -d

    echo ""
    log_info "Waiting for healthy state..."
    sleep 10

    cmd_status
}

# =============================================================================
# down — Stop containers
# =============================================================================
cmd_down() {
    cd "$INSTALL_DIR"
    log_info "Stopping LINBO Docker containers..."
    docker compose --profile dhcp down
}

# =============================================================================
# status — Show container status
# =============================================================================
cmd_status() {
    cd "$INSTALL_DIR"
    [[ ! -f .env ]] && { log_error "Not configured. Run: linbo-docker setup"; exit 1; }

    echo ""
    echo -e "${BOLD}LINBO Docker Status${NC}"
    echo ""

    # Container status
    docker compose --profile dhcp ps --format "table {{.Name}}\t{{.Status}}\t{{.Ports}}" 2>/dev/null

    # API health
    echo ""
    local health
    health=$(curl -s --max-time 3 http://localhost:3000/health 2>/dev/null)
    if [[ -n "$health" ]]; then
        local api_status redis_status ws_clients
        api_status=$(echo "$health" | jq -r '.status // "unknown"')
        redis_status=$(echo "$health" | jq -r '.services.redis // "unknown"')
        ws_clients=$(echo "$health" | jq -r '.websocketClients // 0')
        echo -e "  API:        ${GREEN}${api_status}${NC}"
        echo -e "  Redis:      ${GREEN}${redis_status}${NC}"
        echo "  WS Clients: ${ws_clients}"
    else
        echo -e "  API:        ${RED}not reachable${NC}"
    fi

    # Sync info
    local sync_mode
    sync_mode=$(curl -s --max-time 3 http://localhost:3000/api/v1/sync/mode 2>/dev/null)
    if [[ -n "$sync_mode" ]]; then
        local mode
        mode=$(echo "$sync_mode" | jq -r '.data.mode // "unknown"')
        echo "  Sync Mode:  ${mode}"
    fi

    # .env summary
    if [[ -f .env ]]; then
        echo ""
        echo -e "${BOLD}Configuration${NC}"
        source .env 2>/dev/null
        echo "  Docker IP:  ${LINBO_SERVER_IP:-?}"
        echo "  LMN Server: ${LMN_SERVER_IP:-?}"
        echo "  School:     ${LMN_SCHOOL:-?}"
        echo "  Domain:     ${LINBO_DOMAIN:-?}"
    fi
    echo ""
}

# =============================================================================
# logs — Show container logs
# =============================================================================
cmd_logs() {
    cd "$INSTALL_DIR"
    local container="${1:-api}"
    docker compose logs --tail 50 -f "$container"
}

# =============================================================================
# update — Pull latest and rebuild
# =============================================================================
cmd_update() {
    cd "$INSTALL_DIR"
    log_info "Updating LINBO Docker..."

    if command -v git &>/dev/null && [[ -d .git ]]; then
        git pull --ff-only
    fi

    docker compose build --pull
    docker compose up -d

    log_ok "Update complete"
    cmd_status
}

# =============================================================================
# doctor — Diagnostic checks
# =============================================================================
cmd_doctor() {
    cd "$INSTALL_DIR"
    [[ -f scripts/server/doctor.sh ]] && bash scripts/server/doctor.sh || log_error "doctor.sh not found"
}

# =============================================================================
# Usage
# =============================================================================
usage() {
    echo "linbo-docker v${VERSION} — Modern Caching Server for linuxmuster.net"
    echo ""
    echo "Usage: linbo-docker <command> [options]"
    echo ""
    echo "Commands:"
    echo "  setup         Configure connection to LMN server (auto-discovery)"
    echo "  up [--dhcp]   Start containers (with optional DHCP server)"
    echo "  down          Stop all containers"
    echo "  status        Show container and service status"
    echo "  logs [name]   Show container logs (default: api)"
    echo "  update        Pull latest version and rebuild"
    echo "  doctor        Run diagnostic checks"
    echo ""
    echo "Examples:"
    echo "  linbo-docker setup                          # Interactive setup"
    echo "  linbo-docker setup -i 10.0.0.11 -s gym     # Non-interactive"
    echo "  linbo-docker up --dhcp                      # Start with DHCP"
    echo "  linbo-docker logs dhcp                      # View DHCP logs"
    echo ""
}

usage_setup() {
    echo "Usage: linbo-docker setup [options]"
    echo ""
    echo "Options:"
    echo "  -i, --server-ip IP       LMN Server IP"
    echo "  -s, --school NAME        School name (skip selection)"
    echo "  -p, --password PASS      LMN API password"
    echo "  -t, --token TOKEN        GitHub token for npm"
    echo "  --dhcp-interface IFACE   DHCP interface (default: eth0)"
    echo "  -h, --help               Show this help"
    echo ""
}

# =============================================================================
# Main
# =============================================================================
case "${1:-}" in
    setup)   shift; cmd_setup "$@" ;;
    up)      shift; cmd_up "$@" ;;
    down)    shift; cmd_down "$@" ;;
    status)  cmd_status ;;
    logs)    shift; cmd_logs "$@" ;;
    update)  cmd_update ;;
    doctor)  cmd_doctor ;;
    -v|--version) echo "linbo-docker v${VERSION}" ;;
    -h|--help|"") usage ;;
    *)       log_error "Unknown command: $1"; usage; exit 1 ;;
esac
