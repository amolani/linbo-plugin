#!/bin/sh
set -e

case "$1" in
    configure)
        # Ensure install directory permissions
        chmod 755 /opt/linbo-docker
        chmod 755 /usr/bin/linbo-docker

        # Create data directories
        mkdir -p /var/log/linbo-docker

        echo ""
        echo "============================================"
        echo "  linbo-docker installed successfully!"
        echo ""
        echo "  Run setup:"
        echo "    linbo-docker setup"
        echo ""
        echo "  Or with school name:"
        echo "    linbo-docker setup -s default-school"
        echo ""
        echo "  Then start:"
        echo "    linbo-docker up"
        echo "============================================"
        echo ""
        ;;
esac

#DEBHELPER#

exit 0
